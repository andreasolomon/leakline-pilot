PORT=8787
APP_BASE_URL=http://localhost:8787
VITE_PUBLIC_CONTACT_EMAIL=
AUTO_SYNC_MINUTES=15
LEAKLINE_DATA_DIR=.data
# Use a stable 64-character hex key in deployed environments.
LEAKLINE_ENCRYPTION_KEY=
# Required before sharing a public URL. The first client uses this to create their account.
LEAKLINE_INVITE_CODE=
SESSION_DAYS=30
# Set to true only for local debugging.
LEAKLINE_AUTH_DISABLED=false

# Required for Google Calendar OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/integrations/google-calendar/callback
