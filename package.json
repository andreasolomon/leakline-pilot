{
  "name": "leakline-direction-b",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host localhost --port 8788 --strictPort",
    "dev:server": "PORT=8787 APP_BASE_URL=http://localhost:8787 GOOGLE_REDIRECT_URI=http://localhost:8787/api/integrations/google-calendar/callback tsx watch server/index.ts",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "demo": "npm run build && node scripts/preview.mjs restart",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "preview": "vite preview --host localhost --port 8788 --strictPort",
    "preview:app": "node scripts/preview.mjs start",
    "preview:restart": "node scripts/preview.mjs restart",
    "preview:status": "node scripts/preview.mjs status",
    "preview:stop": "node scripts/preview.mjs stop",
    "start": "node server-dist/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "latest",
    "vitest": "^4.1.9"
  }
}
